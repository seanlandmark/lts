# Copy this to .env and fill in your values, or export these manually in Git Bash.
# Do not commit/share .env because it contains account details.

export SSH_USER='your_cpanel_username'
export SSH_HOST='server123.web-hosting.com'

# Namecheap shared hosting commonly uses port 21098 for SSH.
# If your account says port 22, change this.
export SSH_PORT='21098'

export DB_HOST='localhost'
export DB_PORT='3306'
export DB_USER='your_mysql_user'
export DB_NAME='your_mysql_database'

# Optional: leave commented so the script prompts securely.
# export DB_PASS='your_mysql_password'

# Optional if using key-based SSH:
# export SSH_KEY='/c/Users/Sean/.ssh/namecheap_ed25519'
